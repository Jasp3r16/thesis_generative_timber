{
    "name": "Thesis Computational Environment",
    "image": "mcr.microsoft.com/devcontainers/python:3.11-bookworm", 
    
    "features": {
        "ghcr.io/devcontainers-extra/features/coverage-py:2": {}
    },

    // Zorgt dat je GPU (indien aanwezig) gebruikt kan worden in de container
    "hostRequirements": {
        "gpu": "optional"
    },

    "postCreateCommand": "pip3 install --user -r requirements.txt",

    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-toolsai.jupyter",
                "ms-python.vscode-pylint",
                "ms-azuretools.vscode-docker",
                "christian-kohler.path-intellisense" // Helpt bij je 30/50/60 paden!
            ],
            "settings": {
                "python.defaultInterpreterPath": "/usr/local/bin/python"
            }
        }
    },

    "remoteUser": "vscode"
}